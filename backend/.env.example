# Embedding model used for ChromaDB (pull with: ollama pull nomic-embed-text)
EMBED_MODEL=nomic-embed-text

# Default Ollama host (used for embeddings and for local chat models)
OLLAMA_HOST=http://localhost:11434

# How many items to retrieve from each semantic store per turn
RETRIEVE_K=5

# How many recent turns of short-term memory to include verbatim
SHORT_TERM_TURNS=10
